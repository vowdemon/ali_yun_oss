CHANGELOG_zh.md

# 配置文件和工具目录
.vscode/
.idea/
.dart_tool/
.packages
analysis_options.yaml
.git/
.gitignore

# 其他文件 - 保留LICENSE（pub.dev必需）
git_commit_message.txt
.DS_Store

# 临时和日志文件
*.log
*.env
*.bak
*.tmp
Thumbs.db

# CI/CD 配置
.github/
.travis.yml
.gitlab-ci.yml
