# 排除所有不必要的文件和目录，仅保留发布必需内容

# 示例和测试目录
example/
test/

# 被gitignore忽略但已提交的大文件
example/example/assets/large_file.bin
example/example/assets/example.txt

# 文档文件 - 保留英文版本，排除中文版本
